{
  "name": "agent-notify-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev -- --ignore-rust-version",
    "dev:ui": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build -- --ignore-rust-version",
    "build:sidecars": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-tauri-sidecars.ps1",
    "build:ui": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
